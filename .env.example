VITE_API_BASE_URL=http://localhost:3000

# Host that serves uploaded object reads (question/exam images, OCR previews).
# Defaults to the dev fake-gcs server. With STORAGE_PROVIDER=s3 (Cloudflare R2),
# point this at the backend's GCS-compatible read proxy so image rendering works
# unchanged against a private R2 bucket:
#   VITE_GCS_PUBLIC_HOST=http://localhost:3000/api
# (prod: your API origin or a CDN/Worker that proxies R2)
VITE_GCS_PUBLIC_HOST=http://localhost:4443
