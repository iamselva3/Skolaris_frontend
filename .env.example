VITE_API_BASE_URL=http://localhost:3000

# Host that serves uploaded object reads (question/exam images, OCR previews).
# SKOLARIS is S3/R2-only: reads stream through the backend read-proxy
# (StorageReadController) at /api/storage/v1/b/... against a PRIVATE bucket, so
# this MUST point at the API origin + /api. Leaving it unset falls back to the
# retired fake-gcs host (http://localhost:4443) and every image 404s/breaks.
# (prod: https://<your-api-host>/api)
VITE_GCS_PUBLIC_HOST=http://localhost:3000/api
